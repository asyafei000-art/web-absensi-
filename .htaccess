# ============================================
# .htaccess - Apache Configuration
# ============================================

# Enable mod_rewrite
RewriteEngine On
RewriteBase /web-absensi/

# Redirect HTTP to HTTPS (optional - uncomment jika using SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to certain files
<FilesMatch "\.php$">
    # Allow only specific PHP files
    <Files "*.php">
        # Allow access to api folder
    </Files>
</FilesMatch>

# Prevent access to sensitive files
<Files "config.php">
    Deny from all
</Files>

<Files "database.sql">
    Deny from all
</Files>

<Files "*.sql">
    Deny from all
</Files>

<Files "error.log">
    Deny from all
</Files>

# Cache control for static files
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 week"
    
    # CSS
    ExpiresByType text/css "access plus 1 month"
    
    # JavaScript
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 1 day"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/x-httpd-php
    AddOutputFilterByType DEFLATE image/svg+xml
    AddEncoding gzip svgz
</IfModule>

# Security headers
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set X-XSS-Protection "1; mode=block"
Header set Referrer-Policy "strict-origin-when-cross-origin"

# Allow CORS (optional - uncomment jika perlu)
# Header set Access-Control-Allow-Origin "*"
# Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
# Header set Access-Control-Allow-Headers "Content-Type"

# Remove server signature
Header unset Server
Header unset X-Powered-By

# Default file
DirectoryIndex index.html index.php

# 404 error page (optional)
# ErrorDocument 404 /404.html

# 500 error page (optional)
# ErrorDocument 500 /500.html

# ============================================
# END .htaccess
# ============================================
